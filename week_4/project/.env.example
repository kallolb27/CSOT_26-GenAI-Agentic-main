# ==========================================
# Code Scout / Agent Environment Variables
# ==========================================

# OpenRouter Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=poolside/laguna-m.1:free

# Search & External Tools
SERPER_API_KEY=your_serper_api_key_here

# Hugging Face (If applicable for local embeddings/models)
HF_TOKEN=your_huggingface_token_here

# Workspace & File System
# Absolute or relative path to the directory the agent is allowed to modify
WORKSPACE_ROOT=./target_repo