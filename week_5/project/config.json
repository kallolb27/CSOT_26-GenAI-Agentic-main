{
  "mcpServers": {
    "github": {
      "type": "sse",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": { "Authorization": "Bearer ${GITHUB_PAT}" }
    },
    "sqlite": {
      "type": "stdio",
      "command": "python",
      "args": ["-m", "uv", "tool", "run", "mcp-server-sqlite", "--db-path", "sandbox.db"]
    }
  }
}